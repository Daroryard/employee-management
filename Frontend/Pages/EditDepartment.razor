@page "/departments/edit/{Id:int}"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container-fluid mt-4 text-start" style="max-width: 600px;margin-left:0px !important;">
    <div class="card shadow border-warning">
        <div class="card-header bg-warning"><h5><i class="fa-solid fa-pen-to-square me-2"></i> แก้ไขแผนก</h5></div>
        <div class="card-body">
            @if (editDept == null)
            {
                <p>Loading...</p>
            }
            else
            {
                <EditForm Model="editDept" OnValidSubmit="HandleUpdate">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label fw-bold">ชื่อแผนก</label>
                        <InputText @bind-Value="editDept.Department_Name" class="form-control" />
                        <ValidationMessage For="@(() => editDept.Department_Name)" class="text-danger" />
                    </div>
                    <hr />
                    <button type="submit" class="btn btn-success">อัปเดต</button>
                    <button type="button" class="btn btn-secondary" @onclick='() => Nav.NavigateTo("departments/list")'>ยกเลิก</button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Department? editDept;

    protected override async Task OnInitializedAsync() =>
        editDept = await Http.GetFromJsonAsync<Department>($"api/Departments/{Id}");

    private async Task HandleUpdate()
    {
		var submitBtn = await JS.InvokeAsync<IJSObjectReference>("document.querySelector", "button[type='submit']");
		await submitBtn.InvokeVoidAsync("setAttribute", "disabled", "disabled");
        var res = await Http.PutAsJsonAsync($"api/Departments/{Id}", editDept);
        if (res.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("showToast", "แก้ไขสำเร็จ!");
            Nav.NavigateTo("departments/list");

        } else {

                var errorMsg = await res.Content.ReadAsStringAsync();

                if (string.IsNullOrEmpty(errorMsg))
                {
                    errorMsg = "เกิดข้อผิดพลาดในการแก้ไขข้อมูล";
                }

                await JS.InvokeVoidAsync("showToast", errorMsg, "error");
            
        }
    }
}