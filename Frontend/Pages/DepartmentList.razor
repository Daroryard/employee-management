@page "/departments/list"
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3 text-start">
        <h3 class="fw-bold"><i class="fa-solid fa-list me-2"></i> รายชื่อแผนก (@FilteredDepts.Count)</h3>
        <div class="d-flex gap-2">
            <input type="text" class="form-control" placeholder="ค้นหาชื่อแผนก..."
                   @bind="SearchTerm" @bind:event="oninput" @onkeyup="() => CurrentPage = 1" style="width: 250px;" />
            <a href="departments" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> กลับ</a>
        </div>
    </div>

    @if (departments == null)
    {
        <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <table class="table table-hover border text-start">
            <thead class="table-dark">
                <tr>
                    <th style="width: 100px;">#</th>
                    <th>ชื่อแผนก</th>
                    <th class="text-center" style="width: 200px;">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int index = (CurrentPage - 1) * PageSize + 1;
                }
                @foreach (var dept in PagedDepts)
                {

                    <tr>
                        <td>@(index++)</td>
                        <td class="fw-bold">@dept.Department_Name</td>
                        <td class="text-center">
                            <a href="@($"/departments/edit/{dept.Department_ID}")" class="btn btn-warning btn-sm me-1">
                                <i class="fa-solid fa-pen"></i> แก้ไข
                            </a>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteDept(dept)">
                                <i class="fa-solid fa-trash"></i> ลบ
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <span>หน้า @CurrentPage / @TotalPages</span>
            <div class="btn-group">
                <button class="btn btn-outline-primary btn-sm" disabled="@(CurrentPage==1)" @onclick="() => CurrentPage--">Prev</button>
                <button class="btn btn-outline-primary btn-sm" disabled="@(CurrentPage==TotalPages)" @onclick="() => CurrentPage++">Next</button>
            </div>
        </div>
    }
</div>

@code {
    private List<Department>? departments;
    private string SearchTerm = "";
    private int CurrentPage = 1;
    private int PageSize = 10;

    private List<Department> FilteredDepts => departments?
        .Where(d => string.IsNullOrWhiteSpace(SearchTerm) || d.Department_Name.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase))
        .ToList() ?? new List<Department>();

    private IEnumerable<Department> PagedDepts => FilteredDepts.Skip((CurrentPage - 1) * PageSize).Take(PageSize);
    private int TotalPages => (int)Math.Ceiling((double)FilteredDepts.Count / PageSize);

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() => departments = await Http.GetFromJsonAsync<List<Department>>("api/Departments");

    private async Task DeleteDept(Department d)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"ยืนยันการลบแผนก {d.Department_Name}?"))
        {
            var res = await Http.DeleteAsync($"api/Departments/{d.Department_ID}");
            if (res.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("showToast", "ลบสำเร็จ!");
                await LoadData();
            }
            else
            {
                var err = await res.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", err); 
            }
        }
    }
}