@page "/employee/add"
@using global::EmployeeManagement.Shared.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms 
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <div class="card shadow" style="max-width: 1000px;">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fa-solid fa-user-plus me-2"></i> เพิ่มพนักงานใหม่</h4>
        </div>
        <div class="card-body">
            @if (departments == null)
            {
                <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
            }
            else
            {
                <EditForm Model="@newEmployee" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">ชื่อ (First Name)</label>
                            <InputText @bind-Value="newEmployee.Employee_First_name" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">นามสกุล (Last Name)</label>
                            <InputText @bind-Value="newEmployee.Employee_Last_name" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold d-block">เพศ</label>
                            <div class="mt-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="gender" id="male" value="Male"
                                    checked="@(newEmployee.Gender == "Male")" @onclick="@(() => newEmployee.Gender = "Male")" />
                                    <label class="form-check-label" for="male">ชาย</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="gender" id="female" value="Female"
                                    checked="@(newEmployee.Gender == "Female")" @onclick="@(() => newEmployee.Gender = "Female")" />
                                    <label class="form-check-label" for="female">หญิง</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">แผนก</label>
                            <InputSelect @bind-Value="newEmployee.Department_ID" class="form-select">
                                <option value="0">-- เลือกแผนก --</option>
                                @foreach (var dept in departments)
                                {
                                    <option value="@dept.Department_ID">@dept.Department_Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">วันเกิด</label>
                            <InputDate @bind-Value="newEmployee.Date_of_Birth" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">วันที่เริ่มงาน</label>
                            <InputDate @bind-Value="newEmployee.Date_Joined" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">ที่อยู่</label>
                            <InputTextArea @bind-Value="newEmployee.Employee_Address" class="form-control" rows="2" />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold d-block">รูปถ่ายพนักงาน</label>

                            @if (!string.IsNullOrEmpty(imageDataUrl))
                            {
                                <div class="mb-3">
                                    <img src="@imageDataUrl" class="img-thumbnail" style="max-height: 200px;" alt="รูปพนักงาน" />
                                </div>
                            }

                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-image"></i></span>
                                <InputFile OnChange="OnInputFileChange" class="form-control" accept=".jpg,.jpeg,.png" />
                            </div>
                            <small class="text-muted">รองรับไฟล์ .jpg, .jpeg, .png ขนาดไม่เกิน 2MB</small>
                            <p class="text-danger mt-1">@fileErrorMessage</p>
                        </div>
                    </div>

                    <div class="mt-4 border-top pt-3 text-start">
                        <button type="submit" class="btn btn-primary px-4 me-2">
                            <i class="fa-solid fa-floppy-disk me-1"></i> บันทึกข้อมูลพนักงาน
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
                            ยกเลิก
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    private Employee newEmployee = new Employee
        {
            Date_of_Birth = DateTime.Now.AddYears(-20),
            Date_Joined = DateTime.Now,
            Gender = "Male",
            Department_ID = 0
        };

    private List<Department>? departments;
    private string? imageDataUrl; 
    private string? fileErrorMessage; 

    protected override async Task OnInitializedAsync()
    {
        try
        {
            departments = await Http.GetFromJsonAsync<List<Department>>("api/Departments");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File; 
        if (file == null) return;

        fileErrorMessage = ""; 

        long maxFileSize = 1024 * 1024 * 2; 
        if (file.Size > maxFileSize)
        {
            fileErrorMessage = "ขนาดไฟล์ใหญ่เกินไป ห้ามเกิน 2MB";
            return;
        }

        var contentType = file.ContentType;
        if (contentType != "image/jpeg" && contentType != "image/png" && contentType != "image/jpg")
        {
            fileErrorMessage = "รองรับเฉพาะไฟล์ .jpg, .jpeg, .png เท่านั้น";
            return;
        }

        try
        {
            var buffers = new byte[file.Size];
            using var stream = file.OpenReadStream(maxFileSize);
            await stream.ReadAsync(buffers);

            string base64String = Convert.ToBase64String(buffers);

            newEmployee.Photo = $"data:{contentType};base64,{base64String}";

            imageDataUrl = newEmployee.Photo;
        }
        catch (Exception ex)
        {
            fileErrorMessage = $"เกิดข้อผิดพลาดในการอ่านไฟล์: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
		var submitBtn = await JS.InvokeAsync<IJSObjectReference>("document.querySelector", "button[type='submit']");
		await submitBtn.InvokeVoidAsync("setAttribute", "disabled", "disabled");
        var response = await Http.PostAsJsonAsync("api/Employees", newEmployee);
        if (response.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("showToast", "บันทึกข้อมูลพนักงานสำเร็จ!");

            await Task.Delay(2000);

            ClearForm();
			await submitBtn.InvokeVoidAsync("removeAttribute", "disabled");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
			await JS.InvokeVoidAsync("showToast", $"เกิดข้อผิดพลาด: {error}", "error");

			await submitBtn.InvokeVoidAsync("removeAttribute", "disabled");
           
        }
    }

    private void ClearForm()
    {
        newEmployee = new Employee
            {
                Date_of_Birth = DateTime.Now.AddYears(-20),
                Date_Joined = DateTime.Now,
                Gender = "Male",
                Department_ID = 0
            };

        imageDataUrl = null;
        fileErrorMessage = null;

        StateHasChanged();
    }

    private void GoBack() => Nav.NavigateTo("employees");
}